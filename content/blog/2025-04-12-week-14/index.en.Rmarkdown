    0.18, 0.20, 0.22, 0.25, 0.27, 0.30, 0.33, 0.35, 0.35  
  )  
) %>% select(-ID)  

# Combine all datasets  
gi_net_data <- bind_rows(  
  pancreas_data,  
  appendix_data,  
  duodenum_data,  
  colon_data,  
  cecum_data,  
  biliary_tract_data,  
  gallbladder_data,  
  anorectal_data,  
  ileum_data,  
  stomach_data,  
  jejunum_data,  
  liver_data,  
  esophagus_data  
)  

# Rename "Older adults" and "Young adults" for better formatting in plots  
combined_dataset <- gi_net_data %>%  
  mutate(Demographic = case_when(  
    Demographic == "Older adults" ~ "Older Adults",  
    Demographic == "Young adults" ~ "Young Adults",  
    TRUE ~ Demographic  
  ))  |> 
  as_tibble()

```


