    0.60, 0.70, 0.90, 1.00, 1.15, 1.20, 1.25, 1.30, 1.30,  
    # Female  
    0.20, 0.22, 0.23, 0.25, 0.27, 0.30, 0.32, 0.35, 0.37, 0.40,   
    0.45, 0.55, 0.65, 0.70, 0.75, 0.80, 0.90, 0.95, 0.95,  
    # Older adults  
    0.65, 0.66, 0.67, 0.69, 0.72, 0.75, 0.80, 0.85, 0.90, 0.95,   
    1.05, 1.20, 1.60, 1.90, 2.30, 3.00, 3.30, 3.40, 3.30,  
    # Young adults  
    0.15, 0.16, 0.17, 0.18, 0.19, 0.20, 0.22, 0.25, 0.28, 0.32,   
    0.38, 0.42, 0.48, 0.58, 0.60, 0.61, 0.62, 0.63, 0.63  
